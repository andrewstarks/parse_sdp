{
  "permissions": {
    "allow": [
      "Bash(busted *)",
      "Bash(docker compose run --rm test *)",
      "Bash(pdftotext *)",
      "Bash(make test)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": ".claude/hooks/commit-gate.sh",
            "statusMessage": "Checking commit gates..."
          }
        ]
      }
    ]
  }
}
